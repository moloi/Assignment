@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Home - Course Enrollment</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="container mt-5 fade-in">
            <div class="jumbotron text-center mb-5">
                <div class="mb-4">
                    <i class="bi bi-mortarboard-fill" style="font-size: 4rem; color: white;"></i>
                </div>
                <h1 class="display-4 mb-3">Welcome Back!</h1>
                <p class="lead mb-4">Ready to continue your learning journey?</p>
                <hr class="my-4" style="border-top: 2px solid rgba(255,255,255,0.3); width: 50%; margin: 2rem auto;" />
                <p class="mb-4">Browse our course catalog and manage your enrollments</p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a class="btn btn-light btn-lg" href="/available-courses" role="button">
                        <i class="bi bi-book-fill me-2"></i>Browse Courses
                    </a>
                    <a class="btn btn-success btn-lg" href="/my-courses" role="button">
                        <i class="bi bi-journal-check me-2"></i>My Courses
                    </a>
                </div>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="card text-center h-100 hover-lift">
                        <div class="card-body">
                            <div class="mb-3">
                                <i class="bi bi-search" style="font-size: 3rem; color: #3b82f6;"></i>
                            </div>
                            <h3 class="card-title">Discover Courses</h3>
                            <p class="card-text">Browse through our catalog of courses across various disciplines</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center h-100 hover-lift">
                        <div class="card-body">
                            <div class="mb-3">
                                <i class="bi bi-person-check-fill" style="font-size: 3rem; color: #10b981;"></i>
                            </div>
                            <h3 class="card-title">Easy Enrollment</h3>
                            <p class="card-text">Enroll in courses with just one click and manage your schedule</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center h-100 hover-lift">
                        <div class="card-body">
                            <div class="mb-3">
                                <i class="bi bi-trophy-fill" style="font-size: 3rem; color: #f59e0b;"></i>
                            </div>
                            <h3 class="card-title">Track Progress</h3>
                            <p class="card-text">Keep track of all your enrolled courses in one place</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center text-white" style="background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%); box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4);">
                        <div class="card-body">
                            <i class="bi bi-book-fill" style="font-size: 2.5rem;"></i>
                            <h2 class="mt-3 mb-0">5+</h2>
                            <p class="mb-0">Courses</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center text-white" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4);">
                        <div class="card-body">
                            <i class="bi bi-people-fill" style="font-size: 2.5rem;"></i>
                            <h2 class="mt-3 mb-0">100+</h2>
                            <p class="mb-0">Students</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center text-white" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); box-shadow: 0 10px 30px rgba(245, 158, 11, 0.4);">
                        <div class="card-body">
                            <i class="bi bi-award-fill" style="font-size: 2.5rem;"></i>
                            <h2 class="mt-3 mb-0">50+</h2>
                            <p class="mb-0">Certificates</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center text-white" style="background: linear-gradient(135deg, #ec4899 0%, #db2777 100%); box-shadow: 0 10px 30px rgba(236, 72, 153, 0.4);">
                        <div class="card-body">
                            <i class="bi bi-star-fill" style="font-size: 2.5rem;"></i>
                            <h2 class="mt-3 mb-0">4.8</h2>
                            <p class="mb-0">Rating</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="container mt-5 fade-in">
            <div class="jumbotron text-center">
                <div class="mb-4">
                    <i class="bi bi-mortarboard-fill" style="font-size: 5rem; color: white;"></i>
                </div>
                <h1 class="display-4 mb-3">Course Enrollment System</h1>
                <p class="lead mb-4">Your gateway to quality education</p>
                <hr class="my-4" style="border-top: 2px solid rgba(255,255,255,0.3); width: 50%; margin: 2rem auto;" />
                <p class="mb-4">Join students learning with us. Create your account to get started!</p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a class="btn btn-light btn-lg" href="/login" role="button">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login
                    </a>
                    <a class="btn btn-success btn-lg" href="/register" role="button">
                        <i class="bi bi-person-plus-fill me-2"></i>Register Now
                    </a>
                </div>
            </div>

            <div class="row g-4 mt-5">
                <div class="col-md-6">
                    <div class="card h-100 hover-lift">
                        <div class="card-body">
                            <div class="mb-3">
                                <i class="bi bi-lightning-charge-fill" style="font-size: 2.5rem; color: #f59e0b;"></i>
                            </div>
                            <h3 class="card-title">Quick & Easy</h3>
                            <p class="card-text">Register in seconds and start learning immediately</p>
                            <ul class="list-unstyled">
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>Instant access</li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>Simple enrollment</li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>User-friendly interface</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 hover-lift">
                        <div class="card-body">
                            <div class="mb-3">
                                <i class="bi bi-shield-fill-check" style="font-size: 2.5rem; color: #10b981;"></i>
                            </div>
                            <h3 class="card-title">Secure & Reliable</h3>
                            <p class="card-text">Your data is protected with industry-standard security</p>
                            <ul class="list-unstyled">
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>Encrypted connections</li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>Secure authentication</li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>Privacy protected</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@page "/my-courses"
@using CourseEnrollment.Shared.DTOs
@using CourseEnrollment.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ICourseService CourseService

<PageTitle>My Courses - Course Enrollment System</PageTitle>

<div class="container mt-4 fade-in">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-5 mb-3">
            <i class="bi bi-journal-check text-gradient"></i> My Enrolled Courses
        </h1>
        <p class="lead text-muted">
            Track and manage all your enrolled courses in one place
        </p>
    </div>
    
    @if (isLoading)
    {
        <div class="text-center mt-5 py-5">
            <div class="spinner-border" style="width: 4rem; height: 4rem; border-width: 0.4rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <h4 class="mt-4 text-muted">Loading your courses...</h4>
        </div>
    }
    else if (!enrollments.Any())
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-book" style="font-size: 4rem; color: #6b7280;"></i>
                <h3 class="mt-4 mb-3">No Enrolled Courses Yet</h3>
                <p class="text-muted mb-4">
                    You haven't enrolled in any courses yet. Start your learning journey today!
                </p>
                <a href="/available-courses" class="btn btn-primary btn-lg">
                    <i class="bi bi-search me-2"></i>Browse Available Courses
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <div class="card-body">
                        <i class="bi bi-book-fill" style="font-size: 2.5rem;"></i>
                        <h2 class="mt-3 mb-0" style="color: white;">@enrollments.Count</h2>
                        <p class="mb-0">Enrolled Courses</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white;">
                    <div class="card-body">
                        <i class="bi bi-award-fill" style="font-size: 2.5rem;"></i>
                        <h2 class="mt-3 mb-0" style="color: white;">@enrollments.Sum(e => GetCourseCredits(e.CourseCode))</h2>
                        <p class="mb-0">Total Credits</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white;">
                    <div class="card-body">
                        <i class="bi bi-calendar-check-fill" style="font-size: 2.5rem;"></i>
                        <h2 class="mt-3 mb-0" style="color: white;">@GetDaysSinceFirstEnrollment()</h2>
                        <p class="mb-0">Days Learning</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Enrolled Courses List -->
        <div class="row g-4">
            @foreach (var enrollment in enrollments.OrderByDescending(e => e.EnrolledDate))
            {
                <div class="col-lg-6">
                    <div class="card h-100" style="border-left: 4px solid #6366f1;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="badge" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">@enrollment.CourseCode</span>
                                </div>
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle-fill me-1"></i>Enrolled
                                </span>
                            </div>
                            
                            <h4 class="card-title mb-3">
                                <i class="bi bi-mortarboard-fill me-2" style="color: #6366f1;"></i>@enrollment.CourseName
                            </h4>
                            
                            <div class="mb-3">
                                <div class="d-flex align-items-center text-muted mb-2">
                                    <i class="bi bi-calendar-event me-2" style="color: #6366f1;"></i>
                                    <small>
                                        <strong>Enrolled:</strong> @enrollment.EnrolledDate.ToString("MMMM dd, yyyy")
                                    </small>
                                </div>
                                <div class="d-flex align-items-center text-muted">
                                    <i class="bi bi-clock-history me-2" style="color: #10b981;"></i>
                                    <small>
                                        <strong>@GetDaysSinceEnrollment(enrollment.EnrolledDate)</strong> days ago
                                    </small>
                                </div>
                            </div>
                            
                            <div class="d-grid">
                                <button class="btn btn-danger" @onclick="() => Unenroll(enrollment.CourseId)">
                                    <i class="bi bi-x-circle-fill me-2"></i>Unenroll from Course
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<EnrollmentDto> enrollments = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadEnrollments();
    }

    private async Task LoadEnrollments()
    {
        isLoading = true;
        enrollments = await CourseService.GetMyEnrollments();
        isLoading = false;
    }

    private async Task Unenroll(int courseId)
    {
        var success = await CourseService.UnenrollFromCourse(courseId);
        if (success)
        {
            await LoadEnrollments();
        }
    }

    private int GetCourseCredits(string courseCode)
    {
        // Simple mapping based on course code
        return courseCode switch
        {
            "CS101" => 3,
            "CS201" => 4,
            "CS301" => 4,
            "CS202" => 3,
            "AZ100" => 3,
            _ => 3
        };
    }

    private int GetDaysSinceEnrollment(DateTime enrolledDate)
    {
        return (DateTime.UtcNow - enrolledDate).Days;
    }

    private int GetDaysSinceFirstEnrollment()
    {
        if (!enrollments.Any()) return 0;
        var firstEnrollment = enrollments.Min(e => e.EnrolledDate);
        return (DateTime.UtcNow - firstEnrollment).Days;
    }
}
